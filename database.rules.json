{
  "rules": {
    "//": "Reglas mínimas no-disruptivas: lectura pública (cron remind.js usa REST), escritura requiere Google Auth.",
    "//-future": "Cuando se migre remind.js a Firebase Admin SDK con service account, cambiar .read a 'auth != null' también.",

    ".read": true,
    ".write": "auth != null",

    "bdg_horarios_v2": {
      ".read": true,
      ".write": "auth != null",

      "lastModified": {
        ".validate": "newData.isNumber()"
      },
      "members": {
        ".validate": "newData.hasChildren() || newData.val() == null"
      },
      "slots": {
        ".validate": "newData.hasChildren() || newData.val() == null"
      },
      "picks": {
        ".validate": "newData.hasChildren() || newData.val() == null"
      },
      "pulse_channels": {
        ".read": true,
        ".write": "auth != null"
      }
    }
  }
}
