{
  "crons": [
    { "path": "/api/remind", "schedule": "0 14 * * *" }
  ],
  "rewrites": [
    { "source": "/favicon.ico", "destination": "/public/favicon.ico" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/50m(.*)", "destination": "/public/50m/index.html" },
    { "source": "/tiktok(.*)", "destination": "/public/tiktok/index.html" },
    { "source": "/pulse(.*)", "destination": "/public/pulse/index.html" },
    { "source": "/inventario(.*)", "destination": "/public/inventario/index.html" },
    { "source": "/restock(.*)", "destination": "/public/restock/index.html" },
    { "source": "/catalogo(.*)", "destination": "/public/catalogo/index.html" },
    { "source": "/diseno(.*)", "destination": "/public/diseno/index.html" },
    { "source": "/live(.*)",  "destination": "/public/live/index.html" },
    { "source": "/penny(.*)", "destination": "/public/penny/index.html" },
    { "source": "/oc(.*)", "destination": "/public/oc/index.html" },
    { "source": "/meta(.*)", "destination": "/public/meta/index.html" },
    { "source": "/curvas(.*)", "destination": "/public/curvas/index.html" },
    { "source": "/(.*)", "destination": "/public/index.html" }
  ]
}
